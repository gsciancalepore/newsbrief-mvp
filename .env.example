# Variables base para facilitar la configuración y documentación
DB_USER=newsbrief_user
DB_PASSWORD=secret_password
DB_NAME=newsbrief_db

# URL de conexión a PostgreSQL (Driver ASÍNCRONO obligatorio para SQLAlchemy 2.0 + FastAPI)
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# URL de conexión a Redis
REDIS_URL=redis://redis:6379/0

# Configuración de Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# Environment (development | production)
ENVIRONMENT=development

# Claves de API y Configuración de Email
GEMINI_API_KEY=tu_clave_aqui
SMTP_SERVER=smtp.ejemplo.com
SMTP_PORT=587
SENDER_EMAIL=tu@email.com
SENDER_PASSWORD=tu_password
DEFAULT_RECIPIENT_EMAIL=admin@ejemplo.com